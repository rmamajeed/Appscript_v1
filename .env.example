# =============================================================================
# RFQ PROCESSOR - Environment Variables
# Copy this file to .env for local testing:
#     cp .env.example .env
# Fill in your values. NEVER commit .env to git.
# In production (Cloud Run), all values are stored in GCP Secret Manager.
# =============================================================================

# --- GCP PROJECT (only needed for Cloud Run deployment) ---
GCP_PROJECT_ID=your-gcp-project-id

# --- GOOGLE DRIVE & SHEETS (same values as in code.gs) ---
PARENT_FOLDER_ID=your-drive-parent-folder-id
SHEET_ID=your-google-sheet-id

# --- GMAIL ---
# The email address of the Gmail account the script reads from.
GMAIL_USER_EMAIL=user@your-domain.com
PROCESSED_LABEL_NAME=PROCESSED_BY_BOT
SEARCH_QUERY=subject:RFQ -label:PROCESSED_BY_BOT

# --- PROCESSING ---
# Number of email threads to process per run.
# Increase from original value of 2 — no time limit when running locally or on Cloud Run.
BATCH_SIZE=20

# Sleep in seconds between processing each thread.
# Prevents hitting Gemini API quota limits. Default matches original Apps Script (30s).
SLEEP_BETWEEN_THREADS=30

# Email domain used to identify INTERNAL (your team) emails for TAT calculation.
# Emails from this domain are treated as "our response"; all others are "customer".
# Mirrors the hardcoded "@orbee.com.qa" check in code.gs.
INTERNAL_DOMAIN=@your-company-domain.com

# --- AI ---
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# AUTHENTICATION — choose ONE of the three methods below
# =============================================================================

# METHOD 1 (Recommended for local/personal Gmail):
# Run 'python auth_setup.py' once. It saves token.json automatically.
# No extra config needed here — main.py picks up token.json automatically.
# OAUTH_TOKEN_PATH=token.json          # default, can override
# OAUTH_CREDENTIALS_PATH=credentials.json  # default, can override

# METHOD 2 (Local testing with Google Workspace Service Account):
# Download your service account key JSON from GCP Console and set the path here.
# SERVICE_ACCOUNT_KEY_PATH=C:/path/to/your-service-account-key.json

# METHOD 3 (Cloud Run / production — paste the full SA JSON as one line):
# SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
